# API Keys
OPENAI_API_KEY=your_openai_key
CLAUDE_API_KEY=your_claude_key
GEMINI_API_KEY=your_gemini_key

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret

# Text-to-Speech
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=default_voice_id

# Video Generation
DID_API_KEY=your_d_id_key
STABILITY_API_KEY=your_stability_key

# Stock Media
PEXELS_API_KEY=your_pexels_key
UNSPLASH_API_KEY=your_unsplash_key

# Database
MONGODB_URI=mongodb://mongo:27017/ai_agent
REDIS_URL=redis://redis:6379

# Vector Database
PINCONE_API_KEY=your_pinecone_key
PINCONE_ENVIRONMENT=your_pinecone_env

# Message Queue
RABBIT_MQ_URL=amqp://rabbitmq:5672

# Server
NODE_ENV=development
PORT=3001
FRONTEND_PORT=3000

# Logging
LOG_LEVEL=info
ELK_ENABLED=true
ELASTIC_URL=http://elasticsearch:9200

# Video Settings
VIDEO_OUTPUT_QUALITY=1080p
VIDEO_FPS=30
VIDEO_CODEC=libx264

# Agent Settings
MAX_CONCURRENT_AGENTS=5
AGENT_TIMEOUT=300000
RETRY_ATTEMPTS=3

# Publishing Schedule
PUBLISH_TIME=14:00
TIMEZONE=UTC

# Miscellaneous
ALLOW_CORS=http://localhost:3000
SECRET_KEY=your_secret_key_here
